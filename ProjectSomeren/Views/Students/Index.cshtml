@model List<ProjectSomeren.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<h1>Students</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Student</a>
</p>

<div class="card mb-3">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-4">
                <input type="text" name="searchLastName" class="form-control" placeholder="Search by last name..." 
                    value="@ViewData["SearchLastName"]" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-info">Search</button>
                <a asp-action="Index" class="btn btn-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        @if (!string.IsNullOrEmpty(ViewData["SearchLastName"]?.ToString()))
        {
            <p>No students found with last name containing "@ViewData["SearchLastName"]"</p>
        }
        else
        {
            <p>No students found.</p>
        }
    </div>
}
else
{
    <p>Total students: <strong>@Model.Count</strong>
        @if (!string.IsNullOrEmpty(ViewData["SearchLastName"]?.ToString()))
        {
            <span>(filtered by last name: <strong>@ViewData["SearchLastName"]</strong>)</span>
        }
    </p>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Last Name</th>
                <th>First Name</th>
                <th>Email</th>
                <th>Enrollment Date</th>
                <th>Telephone Number</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in Model)
            {
                <tr>
                    <td>@student.LastName</td>
                    <td>@student.FirstName</td>
                    <td>@student.Email</td>
                    <td>@student.EnrollmentDate.ToString("yyyy-MM-dd")</td>
                    <td>@student.TelephoneNumber</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@student.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@student.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}