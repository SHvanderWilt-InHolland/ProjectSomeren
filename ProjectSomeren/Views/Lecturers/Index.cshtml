@model List<ProjectSomeren.Models.Lecturer>

@{
    ViewData["Title"] = "Lecturers";
}

<h1>Lecturers</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Add New Lecturer</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Department</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var lecturer in Model)
        {
            <tr>
                <td>@lecturer.FirstName</td>
                <td>@lecturer.LastName</td>
                <td>@lecturer.Email</td>
                <td>@lecturer.Department</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@lecturer.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@lecturer.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

