@model List<ProjectSomeren.Models.Activity>

@{
    ViewData["Title"] = "Activity Supervisors Management";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Activities Management</h1>
        <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">Back to Home</a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var activity in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">@activity.Name</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <strong>Description:</strong>
                                <p>@(activity.Description?.Length > 100 ? activity.Description.Substring(0, 100) + "..." : activity.Description)</p>
                            </div>
                            <div class="mb-3">
                                <strong>Date:</strong>
                                <p>@activity.Date.ToString("dddd, MMMM d, yyyy")</p>
                            </div>
                        </div>
                        <div class="card-footer">
                            <a href="@Url.Action("Manage", "ActivitySupervisors", new { id = activity.Id })" 
                               class="btn btn-primary w-100">
                                <i class="bi bi-people"></i> Manage Supervisors
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i> No activities found. Please create an activity first.
        </div>
    }
</div>