@model List<ProjectSomeren.Models.Activity>

@{
    ViewData["Title"] = "Activity Supervisors Management";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Activities Management</h2>
        <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">Back to Home</a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Activity Title</th>
                        <th>Description</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var activity in Model)
                    {
                        <tr>
                            <td>
                                <strong>@activity.Name</strong>
                            </td>
                            <td>
                                @if (activity.Description?.Length > 60)
                                {
                                    @activity.Description.Substring(0, 60)<text>...</text>
                                }
                                else
                                {
                                    @activity.Description
                                }
                            </td>
                            <td>@activity.Date.ToString("yyyy-MM-dd")</td>
                            <td>
                                <a href="@Url.Action("Manage", "ActivitySupervisors", new { id = activity.Id })" 
                                   class="btn btn-sm btn-primary">
                                    <i class="bi bi-people"></i> Manage Supervisors
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i> No activities found. Please create an activity first.
        </div>
    }
</div>