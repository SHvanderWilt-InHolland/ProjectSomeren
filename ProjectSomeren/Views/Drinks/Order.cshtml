
@model ProjectSomeren.Views.Drinks.OrderModel
@{
    ViewData["Title"] = "Order";
}
<h2>Order Drink</h2>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<form method="post">
    <div class="form-group">
        <label for="student">Student</label>
        <select id="student" asp-for="SelectedStudentId" class="form-control">
            <option value="0">-- select student --</option>
            @foreach (var s in Model.Students)
            {
                <option value="@s.Id">@s.LastName, @s.FirstName (@s.Email)</option>
            }
        </select>
    </div>

    <div class="form-group mt-2">
        <label for="drink">Drink</label>
        <select id="drink" asp-for="SelectedDrinkId" class="form-control">
            <option value="0">-- select drink --</option>
            @foreach (var d in Model.Drinks)
            {
                <option value="@d.Drink_Id">@d.Name - €@d.Price (Stock: @d.Stock)</option>
            }
        </select>
    </div>

    <div class="form-group mt-2">
        <label for="qty">Quantity</label>
        <input id="qty" asp-for="Quantity" type="number" min="1" class="form-control" />
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Place Order</button>
    </div>
</form>

<div class="mt-4">
    <h4>Available Drinks</h4>
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Name</th>
                <th>Price</th>
                <th>VAT</th>
                <th>Stock</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model.Drinks)
            {
                <tr>
                    <td>@d.Name</td>
                    <td>€@d.Price</td>
                    <td>@d.Vat%</td>
                    <td>@d.Stock</td>
                </tr>
            }
        </tbody>
    </table>
</div>
