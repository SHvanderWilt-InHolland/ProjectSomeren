
@model ProjectSomeren.Models.Drink
@{
    ViewData["Title"] = "Delete Drink";
}
<h1>Delete Lecturer</h1>

<h3>Are you sure you want to delete this Drink?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2"> Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">Price</dt>
        <dd class="col-sm-10">@Model.Price</dd>
        <dt class="col-sm-2">Vat</dt>
        <dd class="col-sm-10">@Model.Vat</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Drink_Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>